PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/jobtrack

# Generate a long random string for production (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend origins allowed to call the API (comma-separated). Required when the SPA is on another host (e.g. Vercel).
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
# Preview: add your *.vercel.app preview URL too, comma-separated
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://jobtrack.vercel.app,https://jobtrack-git-main-yourteam.vercel.app
