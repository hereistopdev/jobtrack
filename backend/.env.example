PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/jobtrack

# Generate a long random string for production (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Optional: restrict CORS to your frontend origin, e.g. http://localhost:5173
# CORS_ORIGIN=http://localhost:5173
