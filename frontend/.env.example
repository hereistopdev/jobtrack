# Vite only reads vars prefixed with VITE_. Copy to .env for local dev.

# Local (backend on port 5000)
VITE_API_BASE_URL=http://localhost:5000/api

# On Vercel: add the SAME key in Project → Settings → Environment Variables
# (Production and Preview), then redeploy — .env is not uploaded from git.
# Example when the API is on Render:
# VITE_API_BASE_URL=https://jobtrack-pda9.onrender.com/api
